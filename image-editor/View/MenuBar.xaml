<UserControl x:Class="image_editor.View.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:image_editor.View"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Menu Background="#222222">
            <MenuItem Header="File" FontSize="16" Foreground="WhiteSmoke">
                <MenuItem Name="Open" Header="Open PNG" FontSize="14" Foreground="Black"
                          Click="Open_Click"/>
                <MenuItem Name="Save" Header="Save as PNG" FontSize="14" Foreground="Black"
                          Click="Save_Click"/>
            </MenuItem>
            <MenuItem Header="Edit" FontSize="16" Foreground="WhiteSmoke"/>
        </Menu>
    </Grid>
</UserControl>
